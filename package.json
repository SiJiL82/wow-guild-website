{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/**"
  ],
  "scripts": {
    "db:migrate": "npm --workspace=@repo/database exec npx prisma migrate dev",
    "db:generate": "npm --workspace=@repo/database exec npx prisma generate",
    "build": "tsc -b",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^1.0.0",
    "@eslint/markdown": "^7.5.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "overrides": {
    "@eslint/core": "^0.17.0"
  }
}
